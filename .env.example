# CP Router Optimizer - Environment Configuration
# Zkopírujte tento soubor jako .env a upravte hodnoty

# ===========================================
# API Server
# ===========================================
API_PORT=8888
ENVIRONMENT=production
LOG_LEVEL=info

# ===========================================
# OSRM Configuration (interní Docker síť)
# ===========================================
OSRM_URL=http://osrm:5000

# ===========================================
# cuOpt Configuration (interní Docker síť)
# ===========================================
CUOPT_URL=http://cuopt:8080

# ===========================================
# External Ports (pro přístup z hostitele)
# ===========================================
WEBAPP_PORT=8880
API_EXTERNAL_PORT=8888
OSRM_EXTERNAL_PORT=5050
CUOPT_EXTERNAL_PORT=9080

# ===========================================
# Optimization Defaults
# ===========================================
MAX_VEHICLES=10
MAX_STOPS_PER_ROUTE=150
DEFAULT_VEHICLE_CAPACITY_VOLUME=20000
DEFAULT_VEHICLE_CAPACITY_WEIGHT=15000
DEFAULT_SERVICE_TIME=120
DEFAULT_ALGORITHM=cuopt

# ===========================================
# CORS (pro produkci nastavit konkrétní domény)
# ===========================================
CORS_ORIGINS=*

# ===========================================
# Monitoring (volitelné)
# ===========================================
# PROMETHEUS_ENABLED=true
# SENTRY_DSN=https://...
